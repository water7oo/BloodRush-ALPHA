[sub_resource type="Shader" id="Shader_0gxxm"]
code = "shader_type spatial;
render_mode depth_prepass_alpha;

// MIT License. Made by Leo Peltola
// Inspired by https://threejs.org/examples/webgl_postprocessing_pixel.html

uniform sampler2D DEPTH_TEXTURE : hint_depth_texture, filter_linear_mipmap;
uniform sampler2D SCREEN_TEXTURE : hint_screen_texture, filter_linear_mipmap;
uniform sampler2D NORMAL_TEXTURE : hint_normal_roughness_texture, filter_nearest;


uniform bool shadows_enabled = true;
uniform bool highlights_enabled = true;

uniform float alpha : hint_range(0.0, 1.0, 0.01) = 1.0;
uniform float attenuation_threshold = 1.0;
uniform float highlight_increase = 0.2;
uniform float highlight_max : hint_range(0.0, 1.0, 0.01) = 1.0;

uniform float omnilight_brightness = 1.0;
uniform float omnilight_max = 1.0;
uniform float omnilight_min = 0.0;
uniform float directional_max = 1.0;

uniform float fade_midpoint : hint_range(0.0, 100.0, 0.1) = 5.0;
uniform float fade_gradient_length : hint_range(0.01, 100.0, 0.1) = 2.0;

uniform vec3 magic = vec3(0.06711056f, 0.00583715f, 52.9829189f);
uniform bool uniform_dither = false;
//uniform bool dither = false;
//global uniform float dither_fade_start;
//global uniform float dither_fade_size;
//uniform float dither_height_cutoff : hint_range(-10.0, 10.0) = 1.709;
//uniform float dither_height_gradient : hint_range(0.0, 10.0) = 0.597;


//global uniform float dither_circle_radius;
//global uniform float dither_circle_fade;
//global uniform float dither_circle_y_offset;
//global uniform float dither_circle_x_scale;

uniform float offset_dither_x : hint_range(-100.0, 100.0) = 0.0;
uniform float offset_dither_y : hint_range(-100.0, 100.0) = 0.0;

uniform float uv_scale_x = 50.0;

uniform vec3 player_world_location = vec3(0.0);

varying mat4 model_view_matrix;
varying vec3 vertex_pos;
varying vec3 world_pos;
varying vec3 varying_normal;

float bayer4x4(int x, int y) {
    int index = y * 4 + x;
    float[16] matrix = float[16](
         0.0,  8.0,  2.0, 10.0,
        12.0,  4.0, 14.0,  6.0,
         3.0, 11.0,  1.0,  9.0,
        15.0,  7.0, 13.0,  5.0
    );
    return (matrix[index] + 1.0) / 16.0;
}

float getDepth(vec2 screen_uv, sampler2D depth_texture, mat4 inv_projection_matrix){
//	Credit: https://godotshaders.com/shader/depth-modulated-pixel-outline-in-screen-space/
	float raw_depth = texture(depth_texture, screen_uv)[0];
	vec3 normalized_device_coordinates = vec3(screen_uv * 2.0 - 1.0, raw_depth);
    vec4 view_space = inv_projection_matrix * vec4(normalized_device_coordinates, 1.0);
	view_space.xyz /= view_space.w;
	return -view_space.z;
}

vec3 getPos(float depth, mat4 mvm, mat4 ipm, vec2 suv, mat4 wm, mat4 icm){
  vec4 pos = inverse(mvm) * ipm * vec4((suv * 2.0 - 1.0), depth * 2.0 - 1.0, 1.0);
  pos.xyz /= (pos.w+0.0001*(1.-abs(sign(pos.w))));
  return (pos*icm).xyz+wm[3].xyz;
}

float normalIndicator(vec3 normalEdgeBias, vec3 baseNormal, vec3 newNormal, float depth_diff){
	// Credit: https://threejs.org/examples/webgl_postprocessing_pixel.html
	float normalDiff = dot(baseNormal - newNormal, normalEdgeBias);
	float normalIndicator = clamp(smoothstep(-.01, .01, normalDiff), 0.0, 1.0);
	float depthIndicator = clamp(sign(depth_diff * .25 + .0025), 0.0, 1.0);
	return (1.0 - dot(baseNormal, newNormal)) * depthIndicator * normalIndicator;
}

void vertex(){
    model_view_matrix = VIEW_MATRIX * mat4(INV_VIEW_MATRIX[0], INV_VIEW_MATRIX[1], INV_VIEW_MATRIX[2], MODEL_MATRIX[3]);
	vertex_pos = VERTEX;
	varying_normal = NORMAL;
	world_pos = (MODEL_MATRIX * vec4(VERTEX, 1.0)).xyz;
	}

void fragment() {
	vec2 e = vec2(1.0 / VIEWPORT_SIZE.xy);

	float raw_depth = texture(DEPTH_TEXTURE, SCREEN_UV).r;
	vec3 ndc = vec3(SCREEN_UV * 2.0 - 1.0, raw_depth);
	vec4 view_space_pos = INV_PROJECTION_MATRIX * vec4(ndc, 1.0);
	view_space_pos.xyz /= view_space_pos.w;
	float view_distance = -view_space_pos.z;

	float fade_start = fade_midpoint - (fade_gradient_length * 0.5);
	float fade_end = fade_midpoint + (fade_gradient_length * 0.5);
	float fade_alpha = clamp((view_distance - fade_start) / (fade_end - fade_start), 0.0, 1.0);

//	Shadows
	float depth_diff = 0.0;
	float neg_depth_diff = .5;
	if (shadows_enabled) {
		float depth = getDepth(SCREEN_UV, DEPTH_TEXTURE, INV_PROJECTION_MATRIX);
		float du = getDepth(SCREEN_UV+vec2(0., -1.)*e, DEPTH_TEXTURE, INV_PROJECTION_MATRIX);
		float dr = getDepth(SCREEN_UV+vec2(1., 0.)*e, DEPTH_TEXTURE, INV_PROJECTION_MATRIX);
		float dd = getDepth(SCREEN_UV+vec2(0., 1.)*e, DEPTH_TEXTURE, INV_PROJECTION_MATRIX);
		float dl = getDepth(SCREEN_UV+vec2(-1., 0.)*e, DEPTH_TEXTURE, INV_PROJECTION_MATRIX);
		depth_diff += clamp(du - depth, 0., 1.);
		depth_diff += clamp(dd - depth, 0., 1.);
		depth_diff += clamp(dr - depth, 0., 1.);
		depth_diff += clamp(dl - depth, 0., 1.);
		neg_depth_diff += depth - du;
		neg_depth_diff += depth - dd;
		neg_depth_diff += depth - dr;
		neg_depth_diff += depth - dl;
		neg_depth_diff = clamp(neg_depth_diff, 0., 1.);
		neg_depth_diff = clamp(smoothstep(0.5, 0.5, neg_depth_diff)*10., 0., 1.);
		depth_diff = smoothstep(0.2, 0.3, depth_diff);
//		ALBEDO = vec3(neg_depth_diff);
	}

//	Highlights
	float normal_diff = 0.;
	if (highlights_enabled) {
		vec3 normal = texture(NORMAL_TEXTURE, SCREEN_UV).rgb * 2.0 - 1.0;
		vec3 nu = texture(NORMAL_TEXTURE, SCREEN_UV+vec2(0., -1.)*e).rgb * 2.0 - 1.0;
		vec3 nr = texture(NORMAL_TEXTURE, SCREEN_UV+vec2(1., 0.)*e).rgb * 2.0 - 1.0;
		vec3 nd = texture(NORMAL_TEXTURE, SCREEN_UV+vec2(0., 1.)*e).rgb * 2.0 - 1.0;
		vec3 nl = texture(NORMAL_TEXTURE, SCREEN_UV+vec2(-1., 0.)*e).rgb * 2.0 - 1.0;
		vec3 normal_edge_bias = (vec3(1., 1., 1.));
		normal_diff += normalIndicator(normal_edge_bias, normal, nu, depth_diff);
		normal_diff += normalIndicator(normal_edge_bias, normal, nr, depth_diff);
		normal_diff += normalIndicator(normal_edge_bias, normal, nd, depth_diff);
		normal_diff += normalIndicator(normal_edge_bias, normal, nl, depth_diff);
		normal_diff = smoothstep(0.2, 0.8, normal_diff);
		normal_diff = clamp(normal_diff-neg_depth_diff, 0., 1.);
//		ALBEDO = vec3(normal_diff);
	}

	vec3 original_color = texture(SCREEN_TEXTURE, SCREEN_UV).rgb;
	ALBEDO = original_color;

	float alpha_mask = depth_diff * float(shadows_enabled) + normal_diff * float(highlights_enabled);
	ALPHA = clamp((alpha_mask) * 5.0, 0.0, 1.0) * alpha;// * fade_alpha;


    // Compute distance from object origin to camera
    vec3 object_origin_world = (MODEL_MATRIX * vec4(0.0, 0.0, 0.0, 1.0)).xyz;

	float distance_to_camera;
    if (uniform_dither) {
		distance_to_camera = distance(CAMERA_POSITION_WORLD.xz, object_origin_world.xz); // Whole Object
	} else {
		distance_to_camera = distance(CAMERA_POSITION_WORLD.xz, world_pos.xz); // fragment distance
	}

    // Distance-based dither factor
	//float dither_fade_end = dither_fade_start - dither_fade_size;
    //float final_dither = clamp((distance_to_camera - dither_fade_end) / (dither_fade_start - dither_fade_end), 0.0, 1.0);


    //// === World-Space Height Cutoff ===
    //if (world_pos.y >= dither_height_cutoff) {
        //// Vertical height fade (gradient at cutoff height)
        //float height_factor = 1.0;
        //if (dither_height_gradient > 0.0) {
            //height_factor = clamp(
                //1.0 - (world_pos.y - dither_height_cutoff) / dither_height_gradient,
                //0.0,
                //1.0
            //);
        //}

       // Construct tangent space from normal
	vec3 N = normalize(varying_normal);
	vec3 arbitrary = abs(N.y) < 0.99 ? vec3(0.0, 1.0, 0.0) : vec3(1.0, 0.0, 0.0); // Avoid colinearity
	vec3 T = normalize(cross(arbitrary, N)); // Tangent
	vec3 B = cross(N, T); // Bitangent

	// Project world position into the tangent space
	vec3 local_pos = (MODEL_MATRIX * vec4(world_pos, 0.0)).xyz;
	vec2 proj_uv = vec2(dot(local_pos, T), dot(local_pos, B));

        proj_uv *= uv_scale_x; // scale for dither density

        int x = int(mod(floor(proj_uv.x), 4.0));
        int y = int(mod(floor(proj_uv.y), 4.0));

        float bayer = bayer4x4(x, y);

        // Project player position to screen UV
		vec4 player_view = VIEW_MATRIX * vec4(player_world_location, 1.0);
		vec4 player_proj = PROJECTION_MATRIX * player_view;
		vec2 player_screen_uv = (player_proj.xy / player_proj.w) * 0.5 + 0.5;

		// Apply Y offset in screen space
		//player_screen_uv.y += dither_circle_y_offset;


		// Compute distance from player position in screen space
		vec2 diff = SCREEN_UV - player_screen_uv;
		//diff.x *= dither_circle_x_scale;
		float dist_to_center = length(diff);

		//// Circular mask with fade
		//float circle_mask = clamp(
		    //1.0 - (dist_to_center - dither_circle_radius) / max(dither_circle_fade, 0.001),
		    //0.0,
		    //1.0
		//);
//------------------

		// frag location and angle check
		vec2 uv = FRAGCOORD.xy / VIEWPORT_SIZE;     // 0..1
		vec2 ndca = uv * 2.0 - 1.0;                  // -1..1

		// NDC position with depth
		vec4 clip = vec4(ndca, FRAGCOORD.z * 2.0 - 1.0, 1.0);

		// View space position
		vec4 view_pos = INV_PROJECTION_MATRIX * clip;
		view_pos /= view_pos.w;

		// World space position
		vec4 frag_world_pos = INV_VIEW_MATRIX * view_pos;

		vec2 player_to_camera = CAMERA_POSITION_WORLD.xz - player_world_location.xz;
		vec2 player_to_fragment = world_pos.xz - player_world_location.xz;

		player_to_camera = normalize(player_to_camera);
		player_to_fragment = normalize(player_to_fragment);
		float dot_product = dot(player_to_camera, player_to_fragment);

        //if (dither) {
			////if (final_dither < bayer && height_factor < bayer && circle_mask >= bayer) {
			//if (final_dither < bayer && circle_mask >= bayer && height_factor < bayer) {
	            //discard;
        	//}
		//}
    //}
}


void light() {
	if (ATTENUATION > attenuation_threshold) { // IN LIGHT
		DIFFUSE_LIGHT += clamp(dot(NORMAL, LIGHT), highlight_max, highlight_max) * highlight_increase;
		//DIFFUSE_LIGHT += clamp(dot(NORMAL, LIGHT), shadow_mind, shadow_decrease) * ATTENUATION * LIGHT_COLOR;
}
if (LIGHT_IS_DIRECTIONAL == false) {
	DIFFUSE_LIGHT += clamp(dot(NORMAL, LIGHT), omnilight_min, omnilight_max) * (ATTENUATION * omnilight_brightness);
}
if (LIGHT_IS_DIRECTIONAL == true) {
	DIFFUSE_LIGHT += clamp(dot(NORMAL, LIGHT), 0.0, directional_max) * ATTENUATION * LIGHT_COLOR;
	//if (ATTENUATION > attenuation_threshold) {
		//DIFFUSE_LIGHT += clamp(dot(NORMAL, LIGHT), 0.0, highlight_increase) * ATTENUATION * LIGHT_COLOR;
		////DIFFUSE_LIGHT += clamp(dot(NORMAL, LIGHT), 0.0, highlight_increase) * ATTENUATION * LIGHT_COLOR;
//}
}}"

